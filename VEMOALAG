-- ================= НАСТРОЙКИ =================
local smoothing = 1

local NORMAL_FOV = 300
local DANGER_FOV = 420
local DANGER_DISTANCE = 45

-- ================= СЕРВИСЫ =================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- ================= FOV КРУГ =================
local FOVring = Drawing.new("Circle")
FOVring.Visible = true
FOVring.Radius = NORMAL_FOV
FOVring.Thickness = 1.5
FOVring.Transparency = 1
FOVring.Color = Color3.fromRGB(255, 255, 255)
FOVring.Filled = false

-- ================= ESP =================
local ESP = {}

local function createESP(plr)
    if plr == LocalPlayer then return end

    local text = Drawing.new("Text")
    text.Center = true
    text.Outline = true
    text.Size = 16
    text.Visible = false
    ESP[plr] = text
end

local function removeESP(plr)
    if ESP[plr] then
        ESP[plr]:Remove()
        ESP[plr] = nil
    end
end

-- ================= РАДУЖНЫЙ ЦВЕТ =================
local hue = 0
local function getRainbowColor()
    hue += 0.5
    if hue > 360 then hue = 0 end
    return Color3.fromHSV(hue/360, 1, 1)
end

-- ================= АИМБОТ =================
local function getClosestTarget()
    local closest, dist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character
        and plr.Character:FindFirstChild("Head")
        and plr.Character:FindFirstChild("Humanoid")
        and plr.Character.Humanoid.Health > 0 then

            local pos, onScreen = Camera:WorldToViewportPoint(plr.Character.Head.Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                if mag < FOVring.Radius and mag < dist then
                    dist = mag
                    closest = plr
                end
            end
        end
    end
    return closest
end

-- ================= HUD =================
local HUDText = Drawing.new("Text")
HUDText.Center = true
HUDText.Outline = true
HUDText.Size = 24
HUDText.Text = "TEAK"
HUDText.Position = Vector2.new(Camera.ViewportSize.X/2, 50)
HUDText.Visible = true
HUDText.Transparency = 0.4

-- ================= WARNING =================
local WarningText = Drawing.new("Text")
WarningText.Center = true
WarningText.Outline = true
WarningText.Size = 32
WarningText.Text = "! ENEMY IS NEAR TO YOU !"
WarningText.Color = Color3.fromRGB(255, 0, 0)
WarningText.Position = Vector2.new(Camera.ViewportSize.X/2, 95)
WarningText.Visible = false

-- ================= FPS / PING =================
local StatsText = Drawing.new("Text")
StatsText.Outline = true
StatsText.Size = 20
StatsText.Position = Vector2.new(10, 10)
StatsText.Visible = true

-- ================= ГЛАВНЫЙ ЦИКЛ =================
RunService.RenderStepped:Connect(function(dt)
    local mousePos = UserInputService:GetMouseLocation()
    FOVring.Position = mousePos

    -- AIMBOT
    if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    or UserInputService:IsKeyDown(Enum.KeyCode.E) then
        local target = getClosestTarget()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, target.Character.Head.Position),
                smoothing
            )
        end
    end

    local danger = false

    -- ESP + DISTANCE CHECK
    for plr, text in pairs(ESP) do
        local char = plr.Character
        if not char then text.Visible = false continue end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then text.Visible = false continue end

        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0,2.5,0))
        if onScreen then
            text.Text = plr.Name
            text.Position = Vector2.new(pos.X, pos.Y)
            text.Color = getRainbowColor()
            text.Visible = true
        else
            text.Visible = false
        end

        -- ⚠️ ТОЛЬКО ДИСТАНЦИЯ
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist < DANGER_DISTANCE then
                danger = true
            end
        end
    end

    -- WARNING + FOV
    if danger then
        WarningText.Visible = true
        WarningText.Transparency = math.abs(math.sin(tick()*6))
        FOVring.Radius = DANGER_FOV
    else
        WarningText.Visible = false
        FOVring.Radius = NORMAL_FOV
    end

    -- HUD / STATS
    HUDText.Color = getRainbowColor()
    StatsText.Text = "TEAK | FPS: "..math.floor(1/dt)
end)

-- ================= INIT =================
for _, plr in ipairs(Players:GetPlayers()) do
    createESP(plr)
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)
