local player = Players.LocalPlayer

-- Кэш для хранения хитбоксов (чтобы не искать каждый раз)
local hitboxCache = {}
local lastUpdateTime = 0
local updateInterval = 3 -- секунды

-- Переменные
local autoModifyEnabled = false
local selectedMode = "all"
local selectedHitbox = nil
local selectedCharacterName = ""

-- Оптимизированное получение всех хитбоксов (с кэшем)
local function getAllHitboxes()
    local currentTime = tick()
    
    -- Обновляем кэш только раз в 3 секунды (или при принудительном обновлении)
    if currentTime - lastUpdateTime < updateInterval and next(hitboxCache) then
        return hitboxCache
    end
    
    lastUpdateTime = currentTime
    
    -- Очищаем старый кэш
    for character, _ in pairs(hitboxCache) do
        if not character or not character.Parent then
            hitboxCache[character] = nil
        end
    end
    
    -- Поиск новых хитбоксов
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character.Parent then
            local character = otherPlayer.Character
            if not hitboxCache[character] then
                local hitbox = character:FindFirstChild("HeadHitbox")
                if not hitbox then
                    local head = character:FindFirstChild("Head")
                    if head then
                        hitbox = head:FindFirstChild("HeadHitbox")
                    end
                end
                if hitbox and hitbox:IsA("BasePart") then
                    hitboxCache[character] = hitbox
                end
            end
        end
    end
    
    return hitboxCache
end

-- Применение ко всем (оптимизированное)
local function applyToAllPlayers(sizeValue, transparencyValue)
    local hitboxes = getAllHitboxes()
    local count = 0
    
    for _, hitbox in pairs(hitboxes) do
        if hitbox and hitbox.Parent then
            hitbox.Size = sizeValue
            hitbox.Transparency = transparencyValue
            count = count + 1
        end
    end
    
    if count > 0 then
        -- Не печатаем в консоль при авто-режиме (снижаем нагрузку)
        if not autoModifyEnabled then
            print(string.format("✅ Применено к %d игрокам", count))
        end
    end
    
    return count
end

