-- Оптимизированное обновление списка
local function updatePlayerList()
    for _, child in ipairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local hitboxes = getAllHitboxes()
    local yOffset = 0
    
    for character, hitbox in pairs(hitboxes) do
        if character and character.Parent then
            local name = character.Name
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid and humanoid.DisplayName then
                name = humanoid.DisplayName
            end
            
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 28)
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            btn.Text = name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 11
            btn.BackgroundTransparency = 0.3
            btn.Parent = playerList
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 4)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                selectedHitbox = hitbox
                selectedCharacterName = name
                selectedLabel.Text = "🎯 Цель: " .. name
                selectedLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                
                sizeX.Text = string.format("%.1f", hitbox.Size.X)
                sizeY.Text = string.format("%.1f", hitbox.Size.Y)
                sizeZ.Text = string.format("%.1f", hitbox.Size.Z)
                transInput.Text = string.format("%.2f", hitbox.Transparency)
            end)
        end
    end
    
    if not next(hitboxes) then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, -10, 0, 28)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "Нет игроков"
        emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.TextSize = 11
        emptyLabel.Parent = playerList
    end
end

-- Применение изменений
local function applyChanges()
    local newX = tonumber(sizeX.Text)
    local newY = tonumber(sizeY.Text)
    local newZ = tonumber(sizeZ.Text)
    local newTrans = tonumber(transInput.Text)
    
    if not (newX and newY and newZ and newX > 0 and newY > 0 and newZ > 0) then
        return
    end
    
    if not (newTrans and newTrans >= 0 and newTrans <= 1) then
        return
    end
    
    local newSize = Vector3.new(newX, newY, newZ)
    
    if selectedMode == "all" then
        applyToAllPlayers(newSize, newTrans)
    elseif selectedMode == "single" and selectedHitbox and selectedHitbox.Parent then
        selectedHitbox.Size = newSize
        selectedHitbox.Transparency = newTrans
    end
end

-- Авто-изменение (оптимизированное)
local autoConnection = nil
local function toggleAutoModify()
    autoModifyEnabled = not autoModifyEnabled
    
    if autoModifyEnabled then
        if autoConnection then
            autoConnection:Disconnect()
        end
        
        autoBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        autoBtn.Text = "▶ Авто ВКЛ"
        
        -- Используем task.wait вместо RunService для меньшей нагрузки
        autoConnection = task.spawn(function()
            while autoModifyEnabled do
                task.wait(3) -- Ждём 3 секунды
                if autoModifyEnabled then
                    applyChanges()
                end
            end
        end)
    else
        if autoConnection then
            task.cancel(autoConnection)
            autoConnection = nil
        end
        autoBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
        autoBtn.Text = "⏹ Авто ВЫКЛ"
    end
end

